{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Tejvanta": "Information"
    }
  },
  "AllowedHosts": "*",
  "PostgreSql": {
    "UsePostgreSql": false,
    "ConnectionString": "Host=localhost;Database=tejvanta;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
